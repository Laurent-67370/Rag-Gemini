# ─────────────────────────────────────────────────────────────
#  RAG Multimodal — Gemini Embedding 2
#  Copie ce fichier : cp .env.example .env  puis remplis les clés
# ─────────────────────────────────────────────────────────────

# 1. GEMINI → https://aistudio.google.com → Get API Key → Create API Key
GEMINI_API_KEY=ta_cle_gemini_ici

# 2. OPENROUTER → https://openrouter.ai → Keys → Create
OPENROUTER_API_KEY=ta_cle_openrouter_ici

# 3. PINECONE → https://pinecone.io → API Keys → Create API Key
PINECONE_API_KEY=ta_cle_pinecone_ici

# ── Config optionnelle ──────────────────────────────────────
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-exp-03-07
EMBEDDING_DIMENSION=3072
PINECONE_INDEX_NAME=rag-multimodal
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
FLASK_PORT=5000
